{
  "version": "v0.1",
  "benchmark": {
    "name": "CN-NewsTTS Bench",
    "split": "test_public",
    "records": 800,
    "targets": 1008,
    "auto_evaluable_targets": 992,
    "optional_targets_excluded": 16,
    "audio_per_model": 800,
    "raw_track": true,
    "github": "https://github.com/Jayden-X-L/cn-news-tts-bench",
    "release": "https://github.com/Jayden-X-L/cn-news-tts-bench/releases/tag/v0.1"
  },
  "asr_ensemble": [
    {
      "id": "mimo_v2_5_asr",
