      "source": "API"
    },
    {
      "id": "sensevoice_small",
      "name": "SenseVoiceSmall",
      "source": "open-source local"
    },
    {
      "id": "paraformer_zh",
      "name": "Paraformer-zh",
      "source": "open-source local"
    }
  ],
  "models": {
